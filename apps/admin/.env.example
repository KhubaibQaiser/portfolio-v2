# Admin (apps/admin)
# Copy to .env.local

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public portfolio URL (local: http://localhost:3000)
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Same value as apps/web REVALIDATE_SECRET
REVALIDATE_SECRET=

# Cloudflare R2 (media uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# Resume AI — Anthropic (primary model, Claude Sonnet 4.5)
ANTHROPIC_API_KEY=

# Resume AI — Groq (fast draft, silent fallback, ATS scoring)
GROQ_API_KEY=

# Resume AI — Upstash Redis (per-user rate limiting)
# Optional for local dev; omit to disable rate limiting.
# Safe to share the same Redis project with apps/web chat.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resume AI — daily cost cap (USD) per admin user. Defaults to 5.
RESUME_GEN_DAILY_USD_CAP=5
