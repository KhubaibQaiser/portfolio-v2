# =============================================
# Admin Dashboard (apps/admin) — Environment Variables
# =============================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Web App URL — used for on-demand revalidation after admin saves
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Shared secret for cache revalidation (must match REVALIDATE_SECRET in web app)
REVALIDATE_SECRET=

# Cloudflare R2 (S3-compatible) — required for media uploads in /media
# Public URL should match how assets are served (custom domain or *.r2.dev)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
