# =============================================
# Admin Dashboard (apps/admin) — Environment Variables
# =============================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Web App URL — used for on-demand revalidation after admin saves
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Shared secret for cache revalidation (must match REVALIDATE_SECRET in web app)
REVALIDATE_SECRET=
