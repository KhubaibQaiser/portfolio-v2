# Admin (apps/admin)
# Copy to .env.local

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public portfolio URL (local: http://localhost:3000)
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Same value as apps/web REVALIDATE_SECRET
REVALIDATE_SECRET=

# Cloudflare R2 (media uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
