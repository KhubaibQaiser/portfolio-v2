# Portfolio (apps/web)
# Copy to .env.local

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site URL (local: http://localhost:3000)
NEXT_PUBLIC_SITE_URL=https://khubaibqaiser.com

# Same value as apps/admin REVALIDATE_SECRET
REVALIDATE_SECRET=

# Groq (AI chat)
GROQ_API_KEY=

# GitHub API (optional; improves rate limits for stats)
GITHUB_TOKEN=

# PostHog — analytics, error tracking, session replay (project API key; safe to expose)
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# Ingestion API (US: https://us.i.posthog.com | EU: https://eu.i.posthog.com)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# App URL for toolbar / UI links (US: https://us.posthog.com | EU: https://eu.posthog.com)
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
# Optional: e.g. production, preview, development (registered as a super-property)
NEXT_PUBLIC_POSTHOG_ENVIRONMENT=

# PostHog — server-side / build (optional)
# Same as NEXT_PUBLIC_POSTHOG_ENVIRONMENT or override for API routes
POSTHOG_ENVIRONMENT=
# Personal API key + project ID — required for production source map upload to PostHog (error tracking stack traces)
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=
# PostHog app host for the Next.js config wrapper (defaults in next.config.ts)
POSTHOG_APP_HOST=https://us.posthog.com

# Upstash Redis — chat rate limiting (optional; omit for local dev without Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Max chat POSTs per IP per window (defaults: 10 per 60s)
CHAT_RATE_LIMIT_MAX=10
CHAT_RATE_LIMIT_WINDOW_SEC=60
