# Portfolio (apps/web)
# Copy to .env.local

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site URL (local: http://localhost:3000)
NEXT_PUBLIC_SITE_URL=https://khubaibqaiser.com

# Same value as apps/admin REVALIDATE_SECRET
REVALIDATE_SECRET=

# Groq (AI chat)
GROQ_API_KEY=

# GitHub API (optional; improves rate limits for stats)
GITHUB_TOKEN=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
