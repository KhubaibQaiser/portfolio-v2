# ===========================================
# Portfolio (apps/web) — Environment Variables
# ===========================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site (required)
NEXT_PUBLIC_SITE_URL=https://khubaibqaiser.com

# Revalidation (required — shared secret for admin → portfolio cache busting)
REVALIDATE_SECRET=

# Groq — AI Chat
GROQ_API_KEY=

# GitHub — stats API (optional, higher rate limits with token)
GITHUB_TOKEN=

# Upstash Redis — rate limiting, API caching, visitor counter
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend — contact form email delivery
RESEND_API_KEY=

# Cloudflare Turnstile — bot protection on contact form
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Cloudflare Workers AI — embeddings for RAG
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# PostHog — analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Sentry — error tracking
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
